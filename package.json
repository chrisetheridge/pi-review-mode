{
  "name": "pi-review-mode",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "description": "Pi extension that opens a native review surface for frozen Git diffs.",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "dist",
    "README.md",
    "CONTEXT.md",
    "package.json"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:extension && npm run build:web",
    "clean": "rm -rf dist",
    "build:extension": "tsc -p tsconfig.build.json",
    "build:web": "pnpm --filter pi-review-mode-review-web build",
    "dev:web": "pnpm --filter pi-review-mode-review-web dev",
    "check": "npm run biome:check && npm run typecheck && npm run test -- --run",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build && husky"
  },
  "pi": {
    "extensions": [
      "./dist/extension/src/index.js"
    ]
  },
  "dependencies": {
    "gitdiff-parser": "^0.3.1",
    "glimpseui": "^0.8.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.15.17",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
