{
  "name": "pi-review-mode",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "description": "Pi extension that opens a local browser review surface for frozen Git diffs.",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "dist",
    "README.md",
    "CONTEXT.md",
    "package.json"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:extension && npm run build:web",
    "clean": "rm -rf dist",
    "build:extension": "tsc -p tsconfig.build.json",
    "build:web": "vite build --config apps/review-web/vite.config.ts",
    "dev:web": "vite --config apps/review-web/vite.config.ts --host 127.0.0.1",
    "check": "npm run biome:check && npm run typecheck && npm run test -- --run",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build && husky"
  },
  "pi": {
    "extensions": [
      "./dist/extension/src/index.js"
    ]
  },
  "dependencies": {
    "gitdiff-parser": "^0.3.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  }
}
