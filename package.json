{
  "name": "pi-review-mode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "description": "Pi extension that opens a local browser review surface for frozen Git diffs.",
  "scripts": {
    "build": "pnpm build:extension && pnpm build:web",
    "build:extension": "tsc -p tsconfig.build.json",
    "build:web": "vite build --config src/review-web/vite.config.ts",
    "check": "pnpm biome:check && pnpm typecheck && pnpm test -- --run",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "gitdiff-parser": "^0.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  }
}
